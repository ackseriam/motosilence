{% liquid
  assign block_settings = block.settings
-%}

<div
  class="bundle-picker spacing-style"
  style="{% render 'spacing-style', settings: block_settings %}"
  data-bundle-picker="{{ block.id }}"
  {{ block.shopify_attributes }}
>
  {% if block_settings.title != blank %}
    <div class="bundle-picker__header">{{ block_settings.title }}</div>
  {% endif %}

  <div class="bundle-picker__options" role="radiogroup" aria-label="{{ block_settings.title | escape }}">
    {%- for i in (1..3) -%}
      {%- liquid
        assign label_key    = 'option_' | append: i | append: '_label'
        assign subtitle_key = 'option_' | append: i | append: '_subtitle'
        assign price_key    = 'option_' | append: i | append: '_price'
        assign compare_key  = 'option_' | append: i | append: '_compare_price'
        assign badge_key    = 'option_' | append: i | append: '_badge'
        assign shipping_key = 'option_' | append: i | append: '_free_shipping'
        assign qty_key      = 'option_' | append: i | append: '_quantity'

        assign card_label   = block_settings[label_key]
        assign card_qty     = block_settings[qty_key]
      -%}

      {%- if card_label != blank -%}
        <label class="bundle-picker__card{% if i == 1 %} bundle-picker__card--selected{% endif %}">
          <input
            type="radio"
            class="bundle-picker__qty-radio"
            name="bundle-qty-{{ block.id }}"
            value="{{ card_qty | default: i }}"
            {% if i == 1 %}checked{% endif %}
            aria-label="{{ card_label | escape }}"
          >

          {%- assign badge_text = block_settings[badge_key] -%}
          {%- if badge_text != blank -%}
            <span class="bundle-picker__badge">{{ badge_text }}</span>
          {%- endif -%}

          <div class="bundle-picker__card-inner">
            <span class="bundle-picker__radio-dot"></span>
            <div class="bundle-picker__card-text">
              <span class="bundle-picker__card-title">{{ card_label }}</span>
              {%- assign subtitle_text = block_settings[subtitle_key] -%}
              {%- if subtitle_text != blank -%}
                <span class="bundle-picker__card-subtitle">{{ subtitle_text }}</span>
              {%- endif -%}
            </div>
            <div class="bundle-picker__card-price">
              {%- assign price_text   = block_settings[price_key] -%}
              {%- assign compare_text = block_settings[compare_key] -%}
              {%- if price_text != blank -%}
                <span class="bundle-picker__price">{{ price_text }}</span>
              {%- endif -%}
              {%- if compare_text != blank -%}
                <s class="bundle-picker__compare-price">{{ compare_text }}</s>
              {%- endif -%}
            </div>
          </div>

          {%- if block_settings[shipping_key] -%}
            <div class="bundle-picker__shipping">
              <span class="bundle-picker__shipping-icon">🚚</span>
              <span>+ FREE Shipping</span>
            </div>
          {%- endif -%}
        </label>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

<script>
  (function () {
    var picker = document.querySelector('[data-bundle-picker="{{ block.id }}"]');
    if (!picker) return;

    function updateQuantity(qty) {
      document.querySelectorAll('input[name="quantity"]').forEach(function (input) {
        input.value = qty;
        input.dispatchEvent(new Event('change', { bubbles: true }));
        input.dispatchEvent(new Event('input', { bubbles: true }));
      });
    }

    function syncCards(selectedRadio) {
      picker.querySelectorAll('.bundle-picker__card').forEach(function (card) {
        var radio = card.querySelector('.bundle-picker__qty-radio');
        card.classList.toggle('bundle-picker__card--selected', radio === selectedRadio);
      });
    }

    picker.querySelectorAll('.bundle-picker__qty-radio').forEach(function (radio) {
      radio.addEventListener('change', function () {
        if (radio.checked) {
          syncCards(radio);
          updateQuantity(radio.value);
        }
      });
    });

    // Apply default on load
    var defaultRadio = picker.querySelector('.bundle-picker__qty-radio:checked');
    if (defaultRadio) updateQuantity(defaultRadio.value);
  })();
</script>

{% stylesheet %}
  .bundle-picker {
    width: 100%;
  }

  /* ── Header "Buy More & Save!" with side lines ── */
  .bundle-picker__header {
    display: flex;
    align-items: center;
    gap: 10px;
    text-align: center;
    font-weight: 700;
    font-size: 0.88em;
    color: #222;
    margin-bottom: 10px;
  }

  .bundle-picker__header::before,
  .bundle-picker__header::after {
    content: '';
    flex: 1;
    height: 1px;
    background: #c5d8ea;
  }

  /* ── Options list ── */
  .bundle-picker__options {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  /* ── Card ── */
  .bundle-picker__card {
    position: relative;
    display: flex;
    flex-direction: column;
    border: 1.5px solid #c5d8ea;
    border-radius: 12px;
    overflow: hidden;
    cursor: pointer;
    transition: border-color 0.15s ease, background 0.15s ease;
    background: #f0f8ff;
  }

  .bundle-picker__card--selected {
    border: 2px solid #1a90f5;
    background: #e4f2ff;
  }

  .bundle-picker__card input[type='radio'] {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
    pointer-events: none;
  }

  /* ── Badge "Most Popular" ── */
  .bundle-picker__badge {
    position: absolute;
    top: 0;
    right: 0;
    background: #e53935;
    color: #fff;
    font-size: 0.7em;
    font-weight: 700;
    padding: 5px 12px;
    border-bottom-left-radius: 10px;
    border-top-right-radius: 10px;
    letter-spacing: 0.03em;
    z-index: 1;
    white-space: nowrap;
  }

  /* ── Card body row ── */
  .bundle-picker__card-inner {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 15px 16px;
  }

  /* ── Radio circle ── */
  .bundle-picker__radio-dot {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    border: 2px solid #b0c8df;
    background: #fff;
    position: relative;
    transition: border-color 0.15s ease, background 0.15s ease;
  }

  .bundle-picker__card--selected .bundle-picker__radio-dot {
    border-color: #1a90f5;
    background: #1a90f5;
    border-width: 2px;
  }

  /* inner white dot */
  .bundle-picker__card--selected .bundle-picker__radio-dot::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #fff;
  }

  /* ── Text block ── */
  .bundle-picker__card-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .bundle-picker__card-title {
    font-weight: 800;
    font-size: 20px;
    line-height: 1.2;
    color: #111;
  }

  .bundle-picker__card-subtitle {
    font-size: 0.78em;
    color: #6a8099;
    font-weight: 400;
  }

  /* ── Price block ── */
  .bundle-picker__card-price {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 1px;
    flex-shrink: 0;
  }

  .bundle-picker__price {
    font-weight: 800;
    font-size: 1.1em;
    color: #111;
    line-height: 1.2;
  }

  .bundle-picker__compare-price {
    font-size: 0.78em;
    color: #8faabb;
    text-decoration: line-through;
  }

  /* ── FREE Shipping banner ── */
  .bundle-picker__shipping {
    display: flex;
    align-items: center;
    gap: 8px;
    background: #1890ff;
    color: #fff;
    width: 100%;
    height: 43px;
    font-size: 0.82em;
    font-weight: 700;
    padding: 7px 16px;
    letter-spacing: 0.01em;
  }

  .bundle-picker__shipping-icon {
    font-size: 1.1em;
    line-height: 1;
  }
{% endstylesheet %}

