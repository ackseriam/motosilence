    {
      "type": "header",
      "content": "Opción 3"
    },
    {
      "type": "text",
      "id": "option_3_subtitle",
      "label": "Subtítulo",
      "default": "6x Earplug Sets"
    },
    {
      "type": "text",
      "id": "option_3_badge",
      "label": "Badge (ej: Most Popular)",
      "info": "Dejar vacío para ocultar."
    },
    {
      "type": "checkbox",
