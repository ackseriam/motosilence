{% liquid
  assign product_resource = closest.product
  if request.visual_preview_mode and product_resource == blank
    assign product_resource = collections.all.products.first
  endif
-%}

{% unless product_resource == blank %}
  {% liquid
    assign block_settings = block.settings
    assign target_name = block_settings.option_name

    assign bundle_option = nil
    for opt in product_resource.options_with_values
      if target_name != blank
        if opt.name == target_name
          assign bundle_option = opt
          break
        endif
      else
        assign bundle_option = opt
        break
      endif
    endfor
  %}

  {% if bundle_option %}
    <variant-picker
      class="bundle-picker spacing-style"
      style="{% render 'spacing-style', settings: block_settings %}"
      data-section-id="{{ section.id }}"
      data-product-id="{{ product_resource.id }}"
      data-block-id="{{ block.id }}"
      data-product-url="{{ product_resource.url }}"
      ref="mainVariantPicker"
      {% if product.id == product_resource.id %}
        data-template-product-match="true"
      {% endif %}
      {{ block.shopify_attributes }}
      {% if request.visual_preview_mode %}
        data-shopify-visual-preview
      {% endif %}
    >
      <form class="bundle-picker__form">
        {% if block_settings.title != blank %}
          <div class="bundle-picker__header">{{ block_settings.title }}</div>
        {% endif %}

        <fieldset
          class="bundle-picker__options"
          data-fieldset-index="{{ bundle_option.position | minus: 1 }}"
          ref="fieldsets[]"
        >
          <legend class="visually-hidden">{{ bundle_option.name | escape }}</legend>

          {%- for option_value in bundle_option.values -%}
            {%- liquid
              assign slot = forloop.index

              # Get the matched variant to read price
              assign target_variant = nil
              assign option_key = 'option' | append: bundle_option.position
              for v in product_resource.variants
                if v[option_key] == option_value.name
                  assign target_variant = v
                  break
                endif
              endfor

              # Per-slot settings
              assign subtitle_key   = 'option_' | append: slot | append: '_subtitle'
              assign badge_key      = 'option_' | append: slot | append: '_badge'
              assign shipping_key   = 'option_' | append: slot | append: '_free_shipping'

              assign subtitle_text  = block_settings[subtitle_key]
              assign badge_text     = block_settings[badge_key]
              assign has_shipping   = block_settings[shipping_key]
            -%}

            <label class="bundle-picker__card{% if option_value.selected %} bundle-picker__card--selected{% endif %}">
              <input
                type="radio"
                name="{{ bundle_option.name | escape }}-{{ block.id }}-{{ product_resource.id }}"
                value="{{ option_value | escape }}"
                aria-label="{{ option_value.name }}"
                {% if option_value.available == false %}aria-disabled="true"{% endif %}
                data-previous-checked="false"
                data-fieldset-index="{{ bundle_option.position | minus: 1 }}"
                data-input-index="{{ forloop.index0 }}"
                data-input-id="{{ bundle_option.position }}-{{ forloop.index0 }}"
                data-option-value-id="{{ option_value.id }}"
                data-option-available="{{ option_value.available }}"
                {% if option_value.variant.id %}data-variant-id="{{ option_value.variant.id }}"{% endif %}
                {% if option_value.selected %}
                  data-current-checked="true"
                  checked
                {% else %}
                  data-current-checked="false"
                {% endif %}
              >

              {% if badge_text != blank %}
                <span class="bundle-picker__badge">{{ badge_text }}</span>
              {% endif %}

              <div class="bundle-picker__card-inner">
                <span class="bundle-picker__radio-dot"></span>
                <div class="bundle-picker__card-text">
                  <span class="bundle-picker__card-title">{{ option_value.name }}</span>
                  {% if subtitle_text != blank %}
                    <span class="bundle-picker__card-subtitle">{{ subtitle_text }}</span>
                  {% endif %}
                </div>
                {% if target_variant %}
                  <div class="bundle-picker__card-price">
                    <span class="bundle-picker__price">{{ target_variant.price | money }}</span>
                    {% if target_variant.compare_at_price > target_variant.price %}
                      <s class="bundle-picker__compare-price">{{ target_variant.compare_at_price | money }}</s>
                    {% endif %}
                  </div>
                {% endif %}
              </div>

              {% if has_shipping %}
                <div class="bundle-picker__shipping">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                  + FREE Shipping
                </div>
              {% endif %}
            </label>
          {%- endfor -%}
        </fieldset>

        <script type="application/json">
          {{ product_resource.selected_or_first_available_variant | json }}
        </script>
      </form>
    </variant-picker>
  {% endif %}
{% endunless %}

{% stylesheet %}
  .bundle-picker {
    width: 100%;
  }

  .bundle-picker__form {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .bundle-picker__header {
    text-align: center;
    font-weight: 600;
    font-size: 0.95em;
    padding: 6px 12px;
    border-top: 1px solid rgb(var(--color-foreground-rgb) / 0.15);
    border-bottom: 1px solid rgb(var(--color-foreground-rgb) / 0.15);
    margin-bottom: 4px;
  }

  .bundle-picker__options {
    border: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  /* Card */
  .bundle-picker__card {
    position: relative;
    display: flex;
    flex-direction: column;
    border: 2px solid rgb(var(--color-foreground-rgb) / 0.18);
    border-radius: 10px;
    overflow: hidden;
    cursor: pointer;
    transition: border-color 0.15s ease;
    background: var(--color-background);
  }

  .bundle-picker__card:has(input:checked),
  .bundle-picker__card--selected {
    border-color: #1a7fcf;
    background: #eef6ff;
  }

  .bundle-picker__card input[type='radio'] {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
    pointer-events: none;
  }

  /* Badge */
  .bundle-picker__badge {
    position: absolute;
    top: 0;
    right: 0;
    background: #d72c2c;
    color: #fff;
    font-size: 0.72em;
    font-weight: 700;
    padding: 4px 10px;
    border-bottom-left-radius: 8px;
    border-top-right-radius: 8px;
    letter-spacing: 0.02em;
    z-index: 1;
  }

  /* Card inner row */
  .bundle-picker__card-inner {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
  }

  /* Radio dot */
  .bundle-picker__radio-dot {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    border: 2px solid rgb(var(--color-foreground-rgb) / 0.35);
    background: var(--color-background);
    position: relative;
    transition: border-color 0.15s ease;
  }

  .bundle-picker__card:has(input:checked) .bundle-picker__radio-dot {
    border-color: #1a7fcf;
    background: #1a7fcf;
  }

  .bundle-picker__card:has(input:checked) .bundle-picker__radio-dot::after {
    content: '';
    position: absolute;
    inset: 3px;
    border-radius: 50%;
    background: #fff;
  }

  /* Text */
  .bundle-picker__card-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .bundle-picker__card-title {
    font-weight: 700;
    font-size: 0.95em;
    line-height: 1.2;
  }

  .bundle-picker__card-subtitle {
    font-size: 0.8em;
    color: rgb(var(--color-foreground-rgb) / 0.6);
  }

  /* Price */
  .bundle-picker__card-price {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 2px;
    flex-shrink: 0;
  }

  .bundle-picker__price {
    font-weight: 700;
    font-size: 1em;
  }

  .bundle-picker__compare-price {
    font-size: 0.78em;
    color: rgb(var(--color-foreground-rgb) / 0.5);
    text-decoration: line-through;
  }

  /* Free shipping footer */
  .bundle-picker__shipping {
    display: flex;
    align-items: center;
    gap: 8px;
    background: #cce8ff;
    color: #0d5fa6;
    font-size: 0.82em;
    font-weight: 600;
    padding: 8px 16px;
  }

  .bundle-picker__shipping svg {
    flex-shrink: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Bundle Picker",
  "settings": [
    {
      "type": "text",
      "id": "option_name",
      "label": "Nombre de la opción",
      "info": "Debe coincidir exactamente con el nombre de la opción del producto (ej: Sets). Dejar vacío = primera opción.",
      "default": "Sets"
    },
    {
      "type": "text",
