{% assign s = block.settings %}

<div
  class="art-star-badge"
  {{ block.shopify_attributes }}
  style="
    gap: {{ s.gap }}px;
    padding-top: {{ s.padding_top }}px;
    padding-bottom: {{ s.padding_bottom }}px;
    --star-badge-color: {{ s.color }};
  "
>
  {%- assign star_count = s.star_count | default: 5 -%}
  <div class="art-star-badge__stars" aria-hidden="true">
    {%- for i in (1..star_count) -%}
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="currentColor"
        style="width: {{ s.star_size }}px; height: {{ s.star_size }}px;"
        aria-hidden="true"
      >
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
      </svg>
    {%- endfor -%}
  </div>

  {%- if s.label != blank -%}
    <span
      class="art-star-badge__label"
      style="font-size: {{ s.label_size }}px; font-weight: {{ s.label_weight }};"
    >{{ s.label }}</span>
  {%- endif -%}
</div>

{% stylesheet %}
  .art-star-badge {
    display: flex;
    flex-direction: row;
    align-items: center;
    color: var(--star-badge-color, #1a8fe0);
    font-family: inherit;
    width: 100%;
  }

  .art-star-badge__stars {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 2px;
    flex-shrink: 0;
  }

  .art-star-badge__stars svg {
    display: block;
    flex-shrink: 0;
  }

  .art-star-badge__label {
    line-height: 1.3;
    white-space: nowrap;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Star Badge",
  "settings": [
    {
      "type": "range",
      "id": "star_count",
      "label": "Number of stars",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 5
    },
    {
      "type": "range",
      "id": "star_size",
      "label": "Star size",
      "min": 10,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label text",
      "default": "1,372+ Happy Riders"
    },
    {
      "type": "range",
      "id": "label_size",
      "label": "Label font size",
      "min": 10,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "label_weight",
      "label": "Label font weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "600"
    },
    {
      "type": "color",
      "id": "color",
      "label": "Color (stars + text)",
      "default": "#1a8fe0"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap: stars ↔ label",
      "min": 0,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 6
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Star Badge",
      "category": "Product"
    }
  ]
}
{% endschema %}
