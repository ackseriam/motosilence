{% assign s = block.settings %}

<div
  class="art-checklist"
  id="art-checklist-{{ block.id }}"
  {{ block.shopify_attributes }}
  style="
    padding-top: {{ s.padding_top }}px;
    padding-bottom: {{ s.padding_bottom }}px;
  "
>

  {% if s.heading != blank %}
    <p
      class="art-checklist__heading"
      style="
        font-size: {{ s.heading_size }}px;
        color: {{ s.heading_color }};
        margin-bottom: {{ s.heading_gap }}px;
      "
    >{{ s.heading }}</p>
  {% endif %}

  <ul class="art-checklist__list" style="gap: {{ s.items_gap }}px;" role="list">

    {% assign items = s.item_1 | append: "|||" | append: s.item_2 | append: "|||" | append: s.item_3 | append: "|||" | append: s.item_4 | append: "|||" | append: s.item_5 | append: "|||" | append: s.item_6 | split: "|||" %}

    {% for item in items %}
      {% assign item_text = item | strip %}
      {% if item_text != blank %}
        <li class="art-checklist__item" style="gap: {{ s.icon_gap }}px;">
          <span class="art-checklist__icon" style="color: {{ s.icon_color }}; width: {{ s.icon_size }}px; height: {{ s.icon_size }}px; flex-shrink: 0;">
            <svg height="100%" width="100%" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" fill="currentColor" aria-hidden="true">
              <path fill="currentColor" stroke-linecap="round" stroke-linejoin="round" d="M504 256c0 136.967-111.033 248-248 248S8 392.967 8 256 119.033 8 256 8s248 111.033 248 248zM227.314 387.314l184-184c6.248-6.248 6.248-16.379 0-22.627l-22.627-22.627c-6.248-6.249-16.379-6.249-22.628 0L216 308.118l-70.059-70.059c-6.248-6.248-16.379-6.248-22.628 0l-22.627 22.627c-6.248 6.248-6.248 16.379 0 22.627l104 104c6.249 6.249 16.379 6.249 22.628.001z"/>
            </svg>
          </span>
          <span
            class="art-checklist__text"
            style="
              font-size: {{ s.text_size }}px;
              color: {{ s.text_color }};
            "
          >{{ item_text }}</span>
        </li>
      {% endif %}
    {% endfor %}

  </ul>
</div>

{% stylesheet %}
  .art-checklist {
    font-family: 'Poppins', sans-serif;
    width: 100%;
  } 

  .art-checklist__heading {
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: 0.3px;
    margin: 0;
  }

  .art-checklist__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .art-checklist__item {
    display: flex;
    flex-direction: row;
    align-items: center;
  }

  .art-checklist__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    line-height: 1;
  }

  .art-checklist__text {
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: 0.3px;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Checklist", 
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading text",
      "default": "Reduce wind noise & ear ringing"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#161723"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading font size",
      "min": 14,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "heading_gap",
      "label": "Gap: heading → items",
      "min": 0,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 14
    },
    {
      "type": "header",
      "content": "Items"
    },
    {
      "type": "text",
      "id": "item_1",
      "label": "Item 1",
      "default": "Reducing harmful wind noise"
    },
    {
      "type": "text",
      "id": "item_2",
      "label": "Item 2",
      "default": "You can still hear the intercom and traffic"
    },
    {
      "type": "text",
      "id": "item_3",
      "label": "Item 3",
      "default": "All day comfort under helmet"
    },
    {
      "type": "text",
      "id": "item_4",
      "label": "Item 4",
      "default": "100-Days Money Back Guarantee"
    },
    {
      "type": "text",
      "id": "item_5",
      "label": "Item 5"
      
    },
    {
      "type": "text",
      "id": "item_6",
      "label": "Item 6"
    },
    {
      "type": "header",
      "content": "Icon"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#3BBBF0"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 14,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 22
    },
    {
      "type": "range",
      "id": "icon_gap",
      "label": "Gap: icon ↔ text",
      "min": 4,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#424153"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "items_gap",
      "label": "Gap between items",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 80, 
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Checklist",
      "category": "Product"
    }
  ]
}
{% endschema %}
