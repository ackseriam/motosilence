{% comment %}
  Artevive Comfort Section — "Comfort for all ears"
  Layout: 2 columns — text left, image right
  BG: white/transparent
{% endcomment %}

<section class="art-comfort" id="art-comfort-section">
  <div class="art-comfort__inner">
    <div class="art-comfort__grid">

      <!-- Left: Text content -->
      <div class="art-comfort__text-col">
        <h2 class="art-comfort__heading">{{ section.settings.heading }}</h2>

        <div class="art-comfort__bullets">

          <div class="art-comfort__bullet">
            <h3 class="art-comfort__bullet-title">{{ section.settings.bullet_1_title }}</h3>
            <p class="art-comfort__bullet-desc">{{ section.settings.bullet_1_desc }}</p>
          </div>

          <div class="art-comfort__bullet">
            <h3 class="art-comfort__bullet-title">{{ section.settings.bullet_2_title }}</h3>
            <p class="art-comfort__bullet-desc">{{ section.settings.bullet_2_desc }}</p>
          </div>

          <div class="art-comfort__bullet">
            <h3 class="art-comfort__bullet-title">{{ section.settings.bullet_3_title }}</h3>
            <p class="art-comfort__bullet-desc">{{ section.settings.bullet_3_desc }}</p>
          </div>

        </div>
      </div>

      <!-- Right: Product image -->
      <div class="art-comfort__image-col">
        {% if section.settings.product_image != blank %}
          <img
            src="{{ section.settings.product_image | img_url: 'master' }}"
            alt="{{ section.settings.product_image.alt | escape }}"
            class="art-comfort__image"
            loading="lazy"
            width="600"
            height="600"
          >
        {% else %}
          <div class="art-comfort__image-placeholder"></div>
        {% endif %}
      </div>

    </div>
  </div>
</section>

<style>
  .art-comfort {
    background-color: #ffffff;
    font-family: 'Poppins', sans-serif;
  }

  .art-comfort__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 60px 40px;
  }

  .art-comfort__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  /* --- Left text --- */
  .art-comfort__text-col {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .art-comfort__heading {
    font-family: 'Poppins', sans-serif;
    font-size: 40px;
    font-weight: 600;
    color: #161723;
    letter-spacing: 0.5px;
    line-height: 1.2;
    margin: 0;
  }

  .art-comfort__bullets {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .art-comfort__bullet {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .art-comfort__bullet-title {
    font-family: 'Poppins', sans-serif;
    font-size: 19px;
    font-weight: 600;
    color: #161723;
    letter-spacing: 0.5px;
    line-height: 1.3;
    margin: 0;
  }

  .art-comfort__bullet-desc {
    font-family: 'Poppins', sans-serif;
    font-size: 16px;
    font-weight: 400;
    color: #424153;
    letter-spacing: 0.5px;
    line-height: 1.6;
    margin: 0;
  }

  /* --- Right image --- */
  .art-comfort__image-col {
    width: 100%;
  }

  .art-comfort__image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    border-radius: 8px;
  }

  .art-comfort__image-placeholder {
    width: 100%;
    aspect-ratio: 1 / 1;
    background-color: #e0e0e0;
    border-radius: 8px;
  }

  /* --- Responsive --- */
  @media screen and (max-width: 749px) {
    .art-comfort__inner {
      padding: 40px 20px;
    }

    .art-comfort__grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .art-comfort__heading {
      font-size: 28px;
    }

    .art-comfort__bullet-title {
      font-size: 17px;
    }

    /* Image comes first on mobile */
    .art-comfort__image-col {
      order: -1;
    }
  }
</style>

{% schema %}
{
  "name": "Artevive Comfort",
  "tag": "div",
  "class": "artevive-comfort-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Comfort for all ears"
    },
    {
      "type": "header",
      "content": "Bullet 1"
    },
    {
      "type": "text",
      "id": "bullet_1_title",
      "label": "Bullet 1 title",
      "default": "All day comfort under helmet"
    },
    {
      "type": "textarea",
      "id": "bullet_1_desc",
      "label": "Bullet 1 description",
      "default": "The earplug hides in your ear canal so it doesn't rub against the helmet, while still being able to easily insert and take out the earplug."
    },
    {
      "type": "header",
      "content": "Bullet 2"
    },
    {
      "type": "text",
      "id": "bullet_2_title",
      "label": "Bullet 2 title",
      "default": "4 Different sizes"
    },
    {
      "type": "textarea",
      "id": "bullet_2_desc",
      "label": "Bullet 2 description",
      "default": "Every order includes 4 different ear tip sizes (S-XL) to fit all ear types!"
    },
    {
      "type": "header",
      "content": "Bullet 3"
    },
    {
      "type": "text",
      "id": "bullet_3_title",
      "label": "Bullet 3 title",
      "default": "No falling out"
    },
    {
      "type": "textarea",
      "id": "bullet_3_desc",
      "label": "Bullet 3 description",
      "default": "The ultra soft silicone adapts to your ear ensuring the earplugs stay in place all the time"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product image (right)"
    }
  ],
  "presets": [
    {
      "name": "Artevive Comfort"
    }
  ]
}
{% endschema %}
