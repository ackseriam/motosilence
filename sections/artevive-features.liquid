{% comment %}
  Artevive Features Section — "Reduce wind noise, still hear the intercom & traffic"
  Layout: 2 columns — product image left, icon features right
  BG: customizable via settings
{% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">

<section
  class="art-features"
  id="art-features-section-{{ section.id }}"
  style="
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="art-features__inner" style="max-width: {{ section.settings.max_width }}px;">
    <div class="art-features__grid" style="gap: {{ section.settings.columns_gap }}px;">

      <!-- Left: Main product image -->
      <div class="art-features__image-col">
        {% if section.settings.main_image != blank %}
          <img
            src="{{ section.settings.main_image | img_url: 'master' }}"
            alt="{{ section.settings.main_image.alt | escape }}"
            class="art-features__main-image"
            style="border-radius: {{ section.settings.image_radius }}px;"
            loading="lazy"
            width="600"
            height="600"
          >
        {% else %}
          <div class="art-features__image-placeholder" style="border-radius: {{ section.settings.image_radius }}px;"></div>
        {% endif %}
      </div>

      <!-- Right: Heading + feature items -->
      <div class="art-features__content-col">
        <h2
          class="art-features__heading"
          style="
            color: {{ section.settings.heading_color }};
            font-size: {{ section.settings.heading_size }}px;
          "
        >{{ section.settings.heading }}</h2>

        <div class="art-features__items">

          {% for i in (1..4) %}
            {% assign icon_key = "icon_" | append: i %}
            {% assign text_key = "feature_text_" | append: i %}
            {% assign icon_val = section.settings[icon_key] %}
            {% assign text_val = section.settings[text_key] %}

            {% if text_val != blank %}
              <div
                class="art-features__item {% unless forloop.last %}art-features__item--border{% endunless %}"
                style="
                  gap: {{ section.settings.icon_text_gap }}px;
                  padding-top: {{ section.settings.item_padding_v }}px;
                  padding-bottom: {{ section.settings.item_padding_v }}px;
                  border-bottom-color: {{ section.settings.divider_color }};
                "
              >
                <div class="art-features__icon-wrap" style="width: {{ section.settings.icon_size }}px; height: {{ section.settings.icon_size }}px;">
                  {% if icon_val != blank %}
                    <img
                      src="{{ icon_val | img_url: 'master' }}"
                      alt=""
                      class="art-features__icon"
                      style="width: {{ section.settings.icon_size }}px; height: {{ section.settings.icon_size }}px;"
                      loading="lazy"
                      width="{{ section.settings.icon_size }}"
                      height="{{ section.settings.icon_size }}"
                    >
                  {% endif %}
                </div>
                <p
                  class="art-features__item-text"
                  style="
                    color: {{ section.settings.text_color }};
                    font-size: {{ section.settings.text_size }}px;
                  "
                >{{ text_val }}</p>
              </div>
            {% endif %}
          {% endfor %}

        </div>
      </div>

    </div>
  </div>
</section>

<style>
  #art-features-section-{{ section.id }} {
    font-family: 'Poppins', sans-serif;
  }

  #art-features-section-{{ section.id }} .art-features__inner {
    margin: 0 auto;
    padding-left: 40px;
    padding-right: 40px;
  }

  #art-features-section-{{ section.id }} .art-features__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
  }

  #art-features-section-{{ section.id }} .art-features__image-col {
    width: 100%;
  }

  #art-features-section-{{ section.id }} .art-features__main-image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  #art-features-section-{{ section.id }} .art-features__image-placeholder {
    width: 100%;
    aspect-ratio: 1 / 1;
    background-color: #e0e0e0;
  }

  #art-features-section-{{ section.id }} .art-features__content-col {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  #art-features-section-{{ section.id }} .art-features__heading {
    font-family: 'Poppins', sans-serif;
    font-weight: 600;
    letter-spacing: 0.5px;
    line-height: 1.2;
    margin: 0;
  }

  #art-features-section-{{ section.id }} .art-features__items {
    display: flex;
    flex-direction: column;
  }

  #art-features-section-{{ section.id }} .art-features__item {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
  }

  #art-features-section-{{ section.id }} .art-features__item--border {
    border-bottom: 1px solid;
  }

  #art-features-section-{{ section.id }} .art-features__icon-wrap {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #art-features-section-{{ section.id }} .art-features__icon {
    object-fit: contain;
    display: block;
  }

  #art-features-section-{{ section.id }} .art-features__item-text {
    font-family: 'Poppins', sans-serif;
    font-weight: 400;
    letter-spacing: 0.5px;
    line-height: 1.6;
    margin: 0;
    padding-top: 4px;
  }

  /* --- Responsive --- */
  @media screen and (max-width: 749px) {
    #art-features-section-{{ section.id }} .art-features__inner {
      padding-left: 20px;
      padding-right: 20px;
    }

    #art-features-section-{{ section.id }} .art-features__grid {
      grid-template-columns: 1fr;
      gap: 28px !important;
    }

    #art-features-section-{{ section.id }} .art-features__heading {
      font-size: {{ section.settings.heading_size | minus: 12 }}px;
    }

    #art-features-section-{{ section.id }} .art-features__image-col {
      order: -1;
    }
  }
</style>

{% schema %}
{
  "name": "Artevive Features",
  "tag": "div",
  "class": "artevive-features-section",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#F8F8F8"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#161723"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Feature text color",
      "default": "#424153"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider line color",
      "default": "#E5E7EB"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading font size",
      "min": 20,
      "max": 72,
      "step": 1,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Feature text font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Layout & Spacing"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Section max width",
      "min": 800,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "columns_gap",
      "label": "Gap between columns",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "item_padding_v",
      "label": "Feature item vertical padding",
      "min": 0,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "icon_text_gap",
      "label": "Gap: icon ↔ text",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Main product image (left)"
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "Image border radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Icons"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 32,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 65
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Reduce wind noise, still hear the intercom & traffic"
    },
    {
      "type": "header",
      "content": "Feature 1"
    },
    {
      "type": "image_picker",
      "id": "icon_1",
      "label": "Icon 1 (–27 dB)"
    },
    {
      "type": "textarea",
      "id": "feature_text_1",
      "label": "Feature 1 text",
      "default": "Reducing the noise by 27 dB it is the perfect mix of offering hearing protection and letting enough sound through to still hear your music/intercom and the traffic arround you"
    },
    {
      "type": "header",
      "content": "Feature 2"
    },
    {
      "type": "image_picker",
      "id": "icon_2",
      "label": "Icon 2 (sound waves)"
    },
    {
      "type": "textarea",
      "id": "feature_text_2",
      "label": "Feature 2 text",
      "default": "Selective sound technology is the secret that allows you to hear everything while reducing the wind noise by a lot"
    },
    {
      "type": "header",
      "content": "Feature 3"
    },
    {
      "type": "image_picker",
      "id": "icon_3",
      "label": "Icon 3 (reusable)"
    },
    {
      "type": "textarea",
      "id": "feature_text_3",
      "label": "Feature 3 text",
      "default": "Forget the one time use earplugs. These are reusable meaning you can use these for life!"
    },
    {
      "type": "header",
      "content": "Feature 4"
    },
    {
      "type": "image_picker",
      "id": "icon_4",
      "label": "Icon 4"
    },
    {
      "type": "textarea",
      "id": "feature_text_4",
      "label": "Feature 4 text"
    }
  ],
  "presets": [
    {
      "name": "Artevive Features"
    }
  ]
}
{% endschema %}
