{% comment %}
  Artevive Reviews Section
  App: Judge.me (confirmed from UI: star ratings, "Verified" badge, review card layout)
  Renders the Judge.me reviews widget via liquid tag.
  BG: white
{% endcomment %}

<section class="art-reviews" id="art-reviews-section">
  <div class="art-reviews__inner">

    {% if section.settings.show_heading and section.settings.heading != blank %}
      <h2 class="art-reviews__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="art-reviews__widget">
      {% render 'judgeme_widgets', widget_type: 'judgeme_review_widget', concierge_install: true, product: product %}
    </div>

  </div>
</section>

<style>
  .art-reviews {
    background-color: #ffffff;
    font-family: 'Poppins', sans-serif;
  }

  .art-reviews__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 60px 40px;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .art-reviews__heading {
    font-family: 'Poppins', sans-serif;
    font-size: 40px;
    font-weight: 600;
    color: #161723;
    letter-spacing: 0.5px;
    line-height: 1.2;
    margin: 0;
    text-align: center;
  }

  .art-reviews__widget {
    width: 100%;
  }

  /* --- Responsive --- */
  @media screen and (max-width: 749px) {
    .art-reviews__inner {
      padding: 40px 16px;
    }

    .art-reviews__heading {
      font-size: 28px;
    }
  }
</style>

{% schema %}
{
  "name": "Artevive Reviews",
  "tag": "div",
  "class": "artevive-reviews-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "Show heading above reviews",
      "default": false
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Our Riders Say"
    }
  ],
  "presets": [
    {
      "name": "Artevive Reviews"
    }
  ]
}
{% endschema %}
